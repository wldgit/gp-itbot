# Telegram
TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here

# OpenAI
OPENAI_API_KEY=put_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
CHROMA_PATH=/app/data/chroma
# Chroma collection
CHROMA_COLLECTION_NAME=knowledge_base
# Если true, перед ingest коллекция удаляется и создается заново.
# Рекомендуется true для полной переиндексации документов.
# Если нужен инкрементальный режим, поставить false.
RECREATE_CHROMA_COLLECTION=true
DOCS_PATH=/app/data/docs
TOP_K=4
# relevance_score = 1 / (1 + distance); больше значение = строже фильтрация
# Если бот часто отвечает "не нашел", снизить до 0.35-0.45
# Если бот отвечает по нерелевантным документам, поднять до 0.55-0.65
MIN_RELEVANCE_SCORE=0.35
# Размер чанка в символах (после clean_text; legacy fallback if profiler off)
CHUNK_SIZE=800
CHUNK_OVERLAP=150
ANONYMIZED_TELEMETRY=False

# Document profiler (LLM preprocessing before chunking)
DOCUMENT_PROFILER_ENABLED=true
DOCUMENT_PROFILER_MODEL=gpt-5-nano
DOCUMENT_PROFILER_CONFIDENCE_THRESHOLD=0.65
DOCUMENT_PROFILER_MAX_INPUT_CHARS=30000
DOCUMENT_PROFILER_PROMPT_FILE=/app/prompts/document_profiler_prompt.md
PREPROCESSING_REPORT_PATH=/app/data/preprocessing_report.json

DEFAULT_CHUNK_MAX_TOKENS=700
DEFAULT_CHUNK_OVERLAP_TOKENS=100
SECTION_MIN_CHUNK_TOKENS=150
FAQ_CHUNK_MAX_TOKENS=450
FAQ_CHUNK_OVERLAP_TOKENS=50
INSTRUCTION_CHUNK_MAX_TOKENS=700
INSTRUCTION_CHUNK_OVERLAP_TOKENS=100
TROUBLESHOOTING_CHUNK_MAX_TOKENS=650
TROUBLESHOOTING_CHUNK_OVERLAP_TOKENS=80
POLICY_CHUNK_MAX_TOKENS=900
POLICY_CHUNK_OVERLAP_TOKENS=120
SUPPORT_CONTACTS_CHUNK_MAX_TOKENS=500
SUPPORT_CONTACTS_CHUNK_OVERLAP_TOKENS=0
REFERENCE_CHUNK_MAX_TOKENS=800
REFERENCE_CHUNK_OVERLAP_TOKENS=100

# Per-user in-memory dialog for the model (user/assistant turns). Even values keep pairs.
CHAT_HISTORY_MAX_MESSAGES=10

# Intent classifier (before RAG)
INTENT_CLASSIFIER_ENABLED=true
INTENT_MODEL=gpt-5-nano
INTENT_PROMPT_FILE=/app/prompts/intent_classifier_prompt.md
# For gpt-5-nano and other reasoning models: minimal or low are usually enough
INTENT_REASONING_EFFORT=low
INTENT_CONFIDENCE_THRESHOLD=0.65
INTENT_OFFTOPIC_CONFIDENCE_THRESHOLD=0.80

# Support contacts (plain text in bot replies)
SUPPORT_EMAIL=it@medretail.com
SUPPORT_TELEGRAM=@it_support_medretail
SUPPORT_PHONE=+7 (495) 100-10-01
SUPPORT_TEAMS=
SUPPORT_PORTAL=

# Email escalation (/support and «Передать в поддержку»)
SUPPORT_EMAIL_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=


# Prompt
SYSTEM_PROMPT_FILE=/app/prompts/system_prompt.md

# Logging
# Available values: sqlite | postgres
LOG_BACKEND=sqlite
SQLITE_LOG_PATH=/app/logs/app_logs.sqlite3

# PostgreSQL is used only when LOG_BACKEND=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gp_itbot_logs
POSTGRES_USER=gp_itbot
POSTGRES_PASSWORD=gp_itbot_password

# App runtime
LOG_LEVEL=INFO
ENVIRONMENT=dev
